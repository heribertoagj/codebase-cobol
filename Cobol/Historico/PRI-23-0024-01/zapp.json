{
    "name": "CCBR",
    "description": "this application to have a target of automatization of the EFIR processing",
    "version": "1.0.0",
    "author": {
      "name": "IBM CORPORATION"
    },
    "propertyGroups": [
      {
        "name": "cobol-local-files",
        "language": "cobol",
        "libraries": [
          {
            "name": "syslib",
            "type": "local",
            "locations": [
              "C:/Users/herib/workspace/cobol/LIBS/**",
              "**/PRI-23-0024-01/**"
            ]
          }
        ]
      },
      {
        "name": "jcl-local-files",
        "language": "jcl",
        "libraries": [
          {
            "name": "syslib",
            "type": "local",
            "locations": [
              "**/PRI-23-0024-01/**"
            ]
          }
        ]
      }
    ],
    "profiles": [
      {
        "name": "RSE-Mappings",
        "type": "rseapi",
        "settings": {
          "mappings": [
            {
              "resource": "**.SAMPLE.COB**",
              "extension": "cbl",
              "transfer": "text",
              "encoding": "IBM-037",
              "memberMappings": [
                {
                  "extension": "dat",
                  "transfer": "binary",
                  "resource": "*DAT"
                }
              ]
            }
          ],          
          "default.encoding": "IBM-037"
        }
      }
    ]
  }
  