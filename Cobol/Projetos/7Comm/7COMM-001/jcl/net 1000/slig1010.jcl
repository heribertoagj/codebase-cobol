//*
//STEP3A   EXEC PGM=SLIG6180,
//       PARM='COBR'
//*
//* ***    ATUALIZA CAMPOS CLIENTE/CARTEIRA.
//*
//MOVCAREN DD DSN=MX.SLIG.MVCARECC(0),
//       DISP=SHR
//EMABERTO DD DSN=*.STEP3.SORT.SORTOUT,
//       DISP=(OLD,DELETE,KEEP)
//MOVTOOKS DD DSN=MX.SLIG.ABERTOCO(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(060000,19800),RLSE),
//       DCB=(MX.A,LRECL=0150,RECFM=FB),
