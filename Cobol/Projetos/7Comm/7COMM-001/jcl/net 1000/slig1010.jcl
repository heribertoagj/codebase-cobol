//PRINTER  DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//SRELCTRL DD SYSOUT=*
//*
//STEP4    EXEC PGM=SLIG5042
//*
