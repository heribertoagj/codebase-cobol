//       SPACE=(CYL,(00800))
//SORTWK12 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK13 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK14 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK15 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK16 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK17 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK18 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK19 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK20 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK21 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK22 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK23 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK24 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP3    EXEC PGM=SLIG6110
//*
//* ***    ATUALIZA NOME, DIRETORIA E GERENCIA DO CLIENTE
//*
//PADRAOE  DD DSN=*.STEP2.SORTOUT,
//       DISP=OLD,
//       DCB=(BUFNO=15)
//MULTBCO  DD DSN=MX.MESU.PRV.MULTBCO(0),
//       DISP=SHR,
//       DCB=(BUFNO=15)
//PADRAOS  DD DSN=MX.SLIG.CLIEDIR(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,16),
//       SPACE=(TRK,(065500,13107),RLSE),
//       DCB=(MX.A,LRECL=0250,RECFM=FB,BUFNO=15)
//SRELCTRL DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP4    EXEC PGM=BRAD0260
//*
//* ***    CLASSIFICA E COMPRIME POR CGC-CLIENTE, FILIAL CLIENTE,
//* ***    CONTROLE CLIENTE,CGC-SACADO,FILIAL-SACADO E CONTROLE-SACADO.
//*
//SORTIN   DD DSN=*.STEP3.PADRAOS,
//       DISP=OLD,
//       DCB=(BUFNO=15)
//SORTOUT  DD DSN=MX.SLIG.CLIENATU(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,16),
//       SPACE=(TRK,(065500,13107),RLSE),
//       DCB=(MX.A,LRECL=0250,RECFM=FB,BUFNO=15)
//SYSIN    DD *
 SORT FIELDS=(13,4.4,A,18,2.4,A,21,2.4,A,90,4.4,A,95,2.4,A,98,2,A),
         FORMAT=BI
 END
