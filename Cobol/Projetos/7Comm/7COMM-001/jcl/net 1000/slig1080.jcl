//SLIG1080 JOB 'SLIG,4975,PR11','D336470',MSGCLASS=Z,REGION=8M,
//       SCHENV=BATCH
//JOBLIB   DD DSN=MX.BIBGERAL,DISP=SHR
//         DD DSN=MJ.BIBGERAL,DISP=SHR
//         DD DSN=DB2M1.R2.DSNLOAD,DISP=SHR
//         DD DSN=SYS1.CEE.SCEERUN,DISP=SHR
//STEP1    EXEC PGM=SLIG6103
//*
//* ***    FORMATA GRUPO SACADO A PARTIR CGC
//*
//CLISACIN DD DSN=MX.SLIG.CLIATUCL(0),
//       DISP=(OLD,DELETE,KEEP),
//       DCB=(BUFNO=15)
//CLISACOU DD DSN=MX.SLIG.CLISACTU(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,30),
//       SPACE=(TRK,(060000,19800),RLSE),
//       DCB=(MX.A,LRECL=0250,RECFM=FB,BUFNO=15),
//       DATACLAS=PRODX37
//SRELCTRL DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP2    EXEC PGM=BRAD0260
//*
//* ***    CLASSIFICA POR BANCO, AGENCIA, CONTA CLIENTE
//*
//SORTIN   DD DSN=*.STEP1.CLISACOU,
//       DISP=OLD,
//       DCB=(BUFNO=15)
//SORTOUT  DD DSN=MX.SLIG.CLISACCL(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,16),
//       SPACE=(TRK,(065500,13107),RLSE),
//       DCB=(MX.A,LRECL=0250,RECFM=FB,BUFNO=15)
//SYSIN    DD *
 SORT FIELDS=(1,1.4,A,3,2.4,A,6,6.4,A),FORMAT=BI
 END
//SORTLIB  DD DSN=SYS1.SORTLIB,
//       DISP=SHR
//SORTWK01 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK02 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
//SORTWK03 DD UNIT=DISCO,
//       SPACE=(CYL,(00800))
