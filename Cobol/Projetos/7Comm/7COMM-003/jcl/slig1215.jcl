//SORTWK05 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK06 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK07 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK08 DD UNIT=DISCO,
//SORTWK09 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK10 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK11 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK12 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK13 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK14 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK15 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK16 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK17 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK18 DD UNIT=DISCO,
//SORTWK19 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK20 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK21 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK22 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK23 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//SORTWK24 DD UNIT=DISCO,
//       SPACE=(CYL,(000050))
//*
//STEP3    EXEC PGM=SLIG6210
//*
//* ***    SUMARIZAR POR CHEQUE
//* ***    PESQUISAR E PREENCHER CAMPOS GRUPO ECONOMICO, NOME E
//* ***    CGC EMITENTE
//*
//       DISP=SHR
//MULTBCO  DD DSN=MX.SLIG.RETMESU.MULTBCO(0),
//       DISP=SHR
//MVTCHQSR DD DSN=*.STEP2.SORT.SORTOUT,
//       DISP=SHR
//QTDEBCO  DD DSN=MX.SLIG.QTDEBCO(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(000010,000002),RLSE),
//       DCB=(MX.A,LRECL=0022,RECFM=FB)
//EMITCHEQ DD DSN=MX.SLIG.EMITCH01(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,10),
//       SPACE=(TRK,(002000,000400),RLSE),
//       DCB=(MX.A,LRECL=0300,RECFM=FB)
//ARQERROS DD DSN=MX.SLIG.ERROCHEQ(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(000010,000002),RLSE),
//MVCHQREL DD DSN=MX.SLIG.MVTCHREL(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,10),
//       SPACE=(TRK,(002000,000400),RLSE),
//       DCB=(MX.A,LRECL=0300,RECFM=FB)
//MVCHDESP DD DSN=MX.SLIG.MVCHDESP(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(000010,000002),RLSE),
//       DCB=(MX.A,LRECL=0300,RECFM=FB)
//MOTDEVOL DD DSN=MX.SLIG.MOTDEVOL(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(000010,000002),RLSE),
//       DCB=(MX.A,LRECL=0010,RECFM=FB)
//SRELCTRL DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*






































