//       UNIT=(DISCO,05),
//       SPACE=(TRK,(006000,1200),RLSE),
//       DCB=(MX.A,LRECL=0300,RECFM=FB)
//SRELCTRL DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP8    EXEC PGM=SLIG6218
//*
//* ***    FORMATA NOME EMITENTE A PARTIR DO CADACLIE.
//*
//MVTCHQSR DD DSN=*.STEP7A.EMICHSNM,
//       DISP=SHR
//CADCLIE  DD DSN=MX.SLIG.CDCLICHD(0),
//EMITCHEQ DD DSN=MX.SLIG.J1218S08.EMITCHEQ(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,10),
