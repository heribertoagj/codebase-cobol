//STEP7A   EXEC PGM=SLIG6290
//*
//* ***    PESQUISA NOME EMITENTE NO SERASA
//*
//EMICHNME DD DSN=*.STEP7.SORT.SORTOUT,
//       DISP=(OLD,DELETE,KEEP)
//CDSERASA DD DSN=MX.RBRF.PRV.JA100S1A.PFPJAF(0),
