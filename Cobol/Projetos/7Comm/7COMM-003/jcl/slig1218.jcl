//SRELCTRL DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP9    EXEC SORTD
//*
//* ***    CLASSIFICAR POR  CGC/FILIAL/CONTROLE DO EMITENTE
//*
//SORTIN   DD DSN=*.STEP7A.EMICHCNM,
//       DISP=SHR
//         DD DSN=*.STEP8.EMITCHEQ,
//       DISP=SHR
//SORTOUT  DD DSN=MX.SLIG.EMITCHEQ(+1),
//       DISP=(,CATLG,DELETE),
//       SPACE=(TRK,(006000,1200),RLSE),
//       DCB=(MX.A,LRECL=0300,RECFM=FB)
//SYSIN    DD *
 SORT FIELDS=(221,9,A,230,4,A,234,2,A),FORMAT=BI
 END
