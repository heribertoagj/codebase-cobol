<customfieldvalues>
<customfieldvalue>{&quot;metric&quot;:3.31,&quot;racional&quot;:&quot;An&#xE1;lise geral: consolidada toda a jornada em 1 EP, pois a hist&#xF3;ria descreve apenas a adequa&#xE7;&#xE3;o do processo batch de libera&#xE7;&#xE3;o de contratos para conformidade regulat&#xF3;ria, sem cria&#xE7;&#xE3;o de novas entidades de neg&#xF3;cio ou integra&#xE7;&#xE3;o com sistemas externos. N&#xE3;o h&#xE1; LF aut&#xF4;nomo (apenas ajuste de layout/mensageria) nem SR (BACEN &#xE9; destino regulat&#xF3;rio, n&#xE3;o consulta de neg&#xF3;cio). Nenhum item vetado, pois n&#xE3;o h&#xE1; fragmenta&#xE7;&#xE3;o, m&#xFA;ltiplos browsers, cosm&#xE9;tica, TAC, adapta&#xE7;&#xE3;o tecnol&#xF3;gica ou CRUD expl&#xED;cito separado.&quot;,&quot;esclarecimentos&quot;:&quot;Nenhum item vetado. N&#xE3;o h&#xE1; LF aut&#xF4;nomo (apenas ajuste de layout/mensageria) nem SR (BACEN &#xE9; destino regulat&#xF3;rio, n&#xE3;o consulta de neg&#xF3;cio).&quot;,&quot;id_descarte&quot;:null,&quot;itens_escopo&quot;:[{&quot;racional&quot;:&quot;Consolida&#xE7;&#xE3;o de jornada fim a fim para adequa&#xE7;&#xE3;o &#xE0; norma.&quot;,&quot;nome&quot;:&quot;Adequa&#xE7;&#xE3;o do Processo de Libera&#xE7;&#xE3;o de Contratos (COR0005) para Conformidade com Cat&#xE1;logo SICOR BACEN 5.12&quot;,&quot;tipificacao&quot;:&quot;Funcionalidade&quot;,&quot;desenvolvimento&quot;:&quot;Altera&#xE7;&#xE3;o&quot;,&quot;explicacao_desenvolvimento&quot;:&quot;Ajuste na jornada de libera&#xE7;&#xE3;o de contratos para eliminar campos descontinuados conforme nova vers&#xE3;o do cat&#xE1;logo.&quot;,&quot;justificativa_item_funcional&quot;:&quot;A altera&#xE7;&#xE3;o impacta diretamente a gera&#xE7;&#xE3;o da mensageria enviada ao BACEN, sendo percebida pelo usu&#xE1;rio final do processo de libera&#xE7;&#xE3;o de contratos.&quot;,&quot;item_funcional&quot;:true,&quot;pontos&quot;:&quot;3.31&quot;}]}</customfieldvalue>
