 END
//*
//STEP22C  EXEC PGM=SBAT8000,
//       COND=(0,NE,STEP22A)
//*
//* ***    ------------------------------------------------------------
//* ***    ENVIA DADOS A SEREM VALIDADOS PELO GESTOR
//* ***    ------------------------------------------------------------
//*
//ARQTRANS DD DSN=*.STEP22B.SORT.SORTOUT,
//       DISP=SHR
//PARM     DD *
04008,EXCLUS08,TXT
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP23   EXEC SORTD
//*
//* ***    GERA ARQUIVO DE EVENTOS SEGUIR NA BONIFICACAO
//* ***    CLASSIFICA POR DT ENVIO MOVIMENTO, ROTINA, NRO ARQUIVO,
//* ***    DATA ENVIO DO MOVIMENTO, ROTINA, NUMERO ARQUIVO,
//* ***    CODIGO SEQUENCIA, CODIGO TARIFA, DATA OCORR
//*
//SORTIN   DD DSN=*.STEP15.SORT.F1ONLY,
//       DISP=OLD
//         DD DSN=*.STEP17.SAIDA,
//       DISP=OLD
//SORTOUT  DD DSN=MX.GFCT.BONIFICA.GFCT1402(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,20),
//       SPACE=(TRK,(065500,13100),RLSE),
//       DCB=(MX.A,LRECL=265,RECFM=FB)
//SYSIN    DD *
 SORT FIELDS=(1,10,CH,A,11,4,CH,A,15,2,PD,A,17,6,PD,A,
              23,3,PD,A,116,10,CH,A),FORMAT=BI
 END
//*
