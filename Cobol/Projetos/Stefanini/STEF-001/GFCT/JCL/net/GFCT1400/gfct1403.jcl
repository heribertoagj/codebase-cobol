//* ***    ------------------------------------------------------------
//*
//LEITURA  DD DSN=*.STEP17.SAIDA,
//       DISP=OLD
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP22B  EXEC SORTD,
//       COND=(0,NE,STEP22A)
//*
//* ***    ------------------------------------------------------------
//* ***    CONVERTE ARQUIVO PARA ZONADO
//* ***    ------------------------------------------------------------
//*
//SORTIN   DD DSN=*.STEP17.SAIDA,
//       DISP=OLD
//SORTOUT  DD DSN=MX.GFCT.J140322B.SORTOUT(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(001000,0500),RLSE),
