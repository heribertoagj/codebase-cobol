//CTL1CNTL DD *
 OPTION COPY,STOPAFT=10000
//*
//STEP21A  EXEC PGM=PLAN0260
//*
//* ***    ------------------------------------------------------------
//* ***    IDENTIFICA SE VAZIO RETURN-CODE = 4, GERA ARQUIVO VAZIO
//* ***    SENAO LIBERA PARA PROXIMO STEP
//* ***    ------------------------------------------------------------
//*
//LEITURA  DD DSN=*.STEP17.ISENTOS,
//       DISP=OLD
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP21B  EXEC SORTD,
//       COND=(0,NE,STEP21A)
//*
//* ***    ------------------------------------------------------------
//* ***    CONVERTE ARQUIVO PARA ZONADO
//* ***    ------------------------------------------------------------
//*
//SORTIN   DD DSN=*.STEP17.ISENTOS,
//       DISP=OLD
//SORTOUT  DD DSN=MX.GFCT.J140321B.SORTOUT(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(001000,0500),RLSE),
//       DCB=(MX.A,LRECL=174,RECFM=FB)
//SYSIN    DD *
 SORT FIELDS=COPY,STOPAFT=100000
 OUTREC FIELDS=(001,010,
                 011,004,
                 015,002,PD,TO=ZD,LENGTH=002,
                 017,006,PD,TO=ZD,LENGTH=011,
                 023,003,PD,TO=ZD,LENGTH=005,
                 026,003,PD,TO=ZD,LENGTH=005,
                 029,003,PD,TO=ZD,LENGTH=005,
                 032,004,PD,TO=ZD,LENGTH=006,
                 036,008,
                 044,001,PD,TO=ZD,LENGTH=001,
                 045,002,PD,TO=ZD,LENGTH=003,
                 047,003,PD,TO=ZD,LENGTH=005,
                 050,007,PD,TO=ZD,LENGTH=013,
                 057,003,PD,TO=ZD,LENGTH=005,
                 060,003,PD,TO=ZD,LENGTH=005,
                 063,007,PD,TO=ZD,LENGTH=013,
                 070,006,PD,TO=ZD,LENGTH=011,
                 076,006,PD,TO=ZD,LENGTH=011,
                 082,006,PD,TO=ZD,LENGTH=011,
                 088,010,
                 098,010,
                 108,002,PD,TO=ZD,LENGTH=003,
                 110,002,PD,TO=ZD,LENGTH=003,
                 112,002,PD,TO=ZD,LENGTH=002,
                 114,002,PD,TO=ZD,LENGTH=002,
                 116,010)
 END
//*
//STEP21C  EXEC PGM=SBAT8000,
//       COND=(0,NE,STEP21A)
//*
//* ***    ------------------------------------------------------------
//* ***    ENVIA DADOS A SEREM VALIDADOS PELO GESTOR
//* ***    ------------------------------------------------------------
//*
//ARQTRANS DD DSN=*.STEP21B.SORT.SORTOUT,
//       DISP=SHR
//PARM     DD *
04008,EXCLUS07,TXT
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP22A  EXEC PGM=PLAN0260
//*
//* ***    ------------------------------------------------------------
