//GFCT1403 JOB 'GFCT,4008,PR14','D336356',MSGCLASS=Z,SCHENV=BATCH
//JOBLIB   DD DSN=MX.BIBGERAL,DISP=SHR
//         DD DSN=DB2M1.R2.DSNLOAD,DISP=SHR
//         DD DSN=SYS1.CEE.SCEERUN,DISP=SHR
//*
//* ***    TRATA TEST DRIVE MENSALIDADE CESTA EXCLUSIVE
//*
//STEP13   EXEC SORTD,
//       PARM='DYNALLOC=(,255),FILSZ=E250000000'
//*
//* ***    CLASSIFICA EVENTOS POR AG/CTA/TARIFA
//*
//SORTIN   DD DSN=MX.GFCT.BONIFICA.GFCT1402(0),
//       DISP=SHR
//SORTOUT  DD DSN=MX.GFCT.J1403S13.SORTOUT(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,20),
//       SPACE=(TRK,(065500,13100),RLSE),
//       DCB=(MX.A,LRECL=265,RECFM=FB),
//       DATACLAS=PRODX37
//SYSIN    DD *
  SORT FIELDS=(47,3,A,50,7,A,23,3,A),FORMAT=BI
  END
//*
//STEP14   EXEC SORTD,
//       PARM='DYNALLOC=(,255),FILSZ=E250000000'
//*
//* ***    CLASSIFICA ENCARTEIRADOS CESTA EXCLUSIVE
//* ***    POR AG/CTA/TARIFA
//*
//SORTIN   DD DSN=MX.GFCT.PRV.EXCLUSIV(0),
//       DISP=SHR
//SORTOUT  DD DSN=MX.GFCT.J1403S14.SORTOUT(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(22200,2800),RLSE),
//       DCB=(MX.A,LRECL=107,RECFM=FB),
//       DATACLAS=PRODX37
//SYSIN    DD *
  SORT FIELDS=(11,3,A,14,4,A,18,3,A),FORMAT=BI
  END
//*
//STEP15   EXEC SORTD
//*
//* ***    BL EVENTOS COM ENCARTEIRADOS CESTA EXCLUSIVE
//*
//SYSOUT   DD SYSOUT=*
//SORTJNF1 DD DSN=*.STEP13.SORT.SORTOUT,
//       DISP=OLD
//SORTJNF2 DD DSN=*.STEP14.SORT.SORTOUT,
//       DISP=OLD
//F1ONLY   DD DSN=MX.GFCT.J1403S15.F1ONLY(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,20),
//       SPACE=(TRK,(065500,13100),RLSE),
//       DCB=(MX.A,LRECL=265,RECFM=FB)
//F2ONLY   DD DSN=MX.GFCT.J1403S15.F2ONLY(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(22200,2800),RLSE),
//       DCB=(MX.A,LRECL=107,RECFM=FB)
//BOTH     DD DSN=MX.GFCT.J1403S15.BOTH(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(22200,2800),RLSE),
//       DCB=(MX.A,LRECL=357,RECFM=FB)
//SYSIN    DD *
 JOINKEYS FILE=F1,FIELDS=(47,3,A,53,4,A,23,3,A),SORTED,NOSEQCK
 JOINKEYS FILE=F2,FIELDS=(11,3,A,14,4,A,18,3,A),SORTED,NOSEQCK
 JOIN UNPAIRED,F1,F2
 REFORMAT FIELDS=(F1:1,265,F2:1,92,?)
 OPTION COPY
 OUTFIL FNAMES=F1ONLY,INCLUDE=(358,1,CH,EQ,C'1'),
 BUILD=(1,265)
 OUTFIL FNAMES=F2ONLY,INCLUDE=(358,1,CH,EQ,C'2'),
 BUILD=(251,107) 
 OUTFIL FNAMES=BOTH,INCLUDE=(358,1,CH,EQ,C'B'),
 BUILD=(1,357)
 END
//*
//STEP16   EXEC PGM=ICETOOL
//*
//* ***    EVENTOS PASSIVEIS DE ISENCAO/DESCONTO
//* ***    CESTA EXCLUSIVE
//*
//ENTRADA  DD DSN=*.STEP15.SORT.BOTH,
//       DISP=OLD
//RELATORI DD DSN=MX.GFCT.J1403S16.RELATORI(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(22200,2800),RLSE),
//       DCB=(MX.A,LRECL=122,RECFM=FB)
//ARQAUXIL DD DSN=MX.GFCT.J1403S16.ARQAUXIL(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(22200,2800),RLSE),
//       DCB=(MX.A,LRECL=22000,RECFM=FB)
//TOOLMSG  DD SYSOUT=*
//DFSMSG   DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//TOOLIN   DD *
 COPY FROM(ENTRADA) TO(ARQAUXIL) USING(CTL1)
 DISPLAY FROM(ARQAUXIL) LIST(RELATORI) -
 TITLE('         BANCO BRADESCO S/A') DATE(DM4.) PAGE -
 TITLE('    PROG0000 - GESTAO, FLEXIB. E COBR. DE TARIFAS') -
 TITLE('CESTA EXCLUISVE - EVENTOS PASSIVEIS DE ISENC/DESC') -
 BETWEEN(1) -
 HEADER('DENVIO-MOVTO-TARIF')        ON(1,10,CH) -
 HEADER('CROTNA-ORIGE-MOVTO')        ON(11,4,CH) -
 HEADER('CNRO-ARQ-MOVTO')            ON(15,2,PD) -
 HEADER('CSEQ-MOVTO')                ON(17,6,PD) -
 HEADER('CSERVC-TARIF')              ON(23,3,PD) -
 HEADER('CAG-DSTNO-MOVTO')           ON(47,3,PD) -
 HEADER('CCTA-DSTNO-MOVTO')          ON(50,7,PD) -
 HEADER('VTARIF-BRUTO-MOVTO')        ON(70,6,PD,F2) -
 HEADER('VTARIF-LIQ-MOVTO')          ON(76,6,PD,F2) -
 HEADER('VTARIF-DEB-MOVTO')          ON(82,6,PD,F2) -
 HEADER('DAGNDA-DEB-MOVTO')          ON(88,10,CH) -
 HEADER('DEFETV-DEB-MOVTO')          ON(98,10,CH) -
 HEADER('CSIT-EVNTO-RECBD')          ON(112,2,PD) -
 HEADER('DOCOR-EVNTO')               ON(116,10,CH) -
