 HEADER('PER-ISENC')                 ON(286,2,PD) -
 HEADER('DATA-ENCART')               ON(288,5,PD) -
 HEADER('DATA-ABERT-CTA')            ON(293,5,PD) -
 HEADER('CD-SEGMENTO')               ON(298,2,PD) -
 HEADER('AAAAMM-COMPET')             ON(300,4,PD) -
 HEADER('TP-DESCONTO')               ON(304,1,PD) -
 HEADER('VR-A-COBRAR')               ON(305,6,PD,F2) -
 HEADER('CSERVC-TARIF-ANT')          ON(311,3,PD) -
 HEADER('AAAAMM-ISENC-DESC')         ON(314,4,PD) -
 LINES(999) -
 BLANK -
 COUNT('EXCLUISVE - PASSIVEIS DE ISENC/DESC --->>> ')
