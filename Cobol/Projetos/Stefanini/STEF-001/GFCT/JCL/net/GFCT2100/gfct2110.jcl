//CADACLIE DD DSN=*.STEP0.SORTOUT,
//       DISP=SHR
//CLIEADES DD DSN=MX.GFCT.CLIEADES(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,30),
//       SPACE=(CYL,(006660,01332),RLSE),
//       DCB=(MX.A,LRECL=0055,RECFM=FB)
//CLIPSCCE DD DSN=MX.GFCT.CLIPSCCE(+1),
