//       UNIT=(DISCO,40),
//       SPACE=(CYL,(006660,01332),RLSE),
//       DCB=(MX.A,LRECL=0090,RECFM=FB)
//CLIEINVA DD DSN=MX.GFCT.CLIEINVA(+1),
