//SYSUDUMP DD SYSOUT=Y
//*
//STEP9    EXEC PGM=GFCT4200,
//       PARM='MENSAL'
//*
//* ***    CONSISTENCIA DE MOVIMENTO
//* ***    ESPURGO MENSAL DE LANCAMENTOS
//* ***    MOVIMENTO PARA RELATORIO DIARIO/MENSAL
//* ***    PARA PARM DIARIO: MESPURGO SEMPRE VAZIO
//* ***    PARA PARM MENSAL: MOVATUAL/INCONSIS SEMPRE VAZIO
//*
//MOVIMENT DD DSN=MX.GFCT.PRV.ACUMKFIS(0),
//       DISP=SHR
//ARQDATAS DD DSN=*.STEP0A.SORT.SORTOUT,
//       DISP=SHR
//MOVATUAL DD DUMMY,
//       DCB=(LRECL=0200,RECFM=FB)
//MESPURGO DD DUMMY,
//       DCB=(LRECL=0200,RECFM=FB)
//MOVTOLIS DD DSN=MX.GFCT.LISCRCMT(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0200,RECFM=FB)
//INCONSIS DD DUMMY,
//       DCB=(LRECL=0200,RECFM=FB)
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP10   EXEC SORTD
//*
//* ***    CLASSIFICA POR ORDEM DA LISTAGEM
//*
//SORTIN   DD DSN=*.STEP9.MOVTOLIS,
//       DISP=SHR
//SORTOUT  DD DSN=MX.GFCT.LISTTCMK(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0200,RECFM=FB)
//SYSIN    DD *
  SORT FIELDS=(1,26,A),FORMAT=BI
  END
//*
//STEP11   EXEC PGM=GFCT4206
//*
//* ***    LISTAGEM MENSAL RECARGAS CELULAR
//*
//MOVIMENT DD DSN=*.STEP10.SORT.SORTOUT,
//       DISP=SHR
//ARQDATAS DD DSN=*.STEP0A.SORT.SORTOUT,
//       DISP=SHR
//RELATORI DD DSN=MX.GFCT.RELCTMET(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0133,RECFM=FB)
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP11A  EXEC PGM=PLAN2440,
//       PARM=001
//*
//* ***    EMITE RELATORIO
//*
//ENT00001 DD DSN=*.STEP11.RELATORI,
//       DISP=SHR
//SAI00001 DD SYSOUT=%%FORM#IOCV,
//       DCB=(LRECL=133,RECFM=FBA)
//SYSOUT   DD SYSOUT=*
//PRINTER  DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
