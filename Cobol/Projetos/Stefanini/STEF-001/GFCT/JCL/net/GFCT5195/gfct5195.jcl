//SORTWK30 DD UNIT=DISCO,
//       SPACE=(CYL,(0500))
//SORTWK31 DD UNIT=DISCO,
//       SPACE=(CYL,(0500))
//SORTWK32 DD UNIT=DISCO,
//       SPACE=(CYL,(0500))
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP0A   EXEC SORTD
//*
//* ***    GERA DATA DE MOVIMENTO GFCT (DPROCM)
//* ***    PARA PROCESSO A PEDIDO
//* ***    POS 001 A 004 TAM 04 - GFCT
//* ***    POS 005 A 014 TAM 10 - DT.MOVTO ANTERIOR
//* ***    POS 015 A 024 TAM 10 - DT.MOVTO ATUAL
//* ***    POS 025 A 034 TAM 10 - DT.MOVTO POSTERIOR
//* ***    POS 035 A 100 TAM 66 - BRANCOS
//*
//* ***    ATENCAO: PARA O PROCESSO EM QUESTAO
//* ***    A DATA ATUAL PRECISA SER PRIMEIRO
//* ***    DIA UTIL DO MES (SEMPRE)
//*
//SORTIN   DD *
GFCT28.01.201101.02.201102.02.2011
//SORTOUT  DD DSN=MX.GFCT.TS2PRCCM(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(100,10),RLSE),
//       DCB=(MX.A,LRECL=100,RECFM=FB)
//SYSIN    DD *
 INREC FIELDS=(1,34,66X)
 SORT FIELDS=COPY
 END
//*
//STEP1    EXEC PGM=GFCT4202,
//       PARM='MENSAL'
//*
//* ***    SELECIONA ADESOES DIARIO/MENSAL
//*
//ARQDATAS DD DSN=*.STEP0A.SORT.SORTOUT,
//       DISP=SHR
//MOVTOCEL DD DSN=MX.GFCT.MOVTTLMQ(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0050,RECFM=FB)
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP1A   EXEC SORTD
//*
//* ***    =============================================================
//* ***    CLASSIFICA POR AGENCIA E CONTA
//* ***    =============================================================
//*
//SORTIN   DD DSN=*.STEP1.MOVTOCEL,
//       DISP=OLD
//SORTOUT  DD DSN=MX.GFCT.MOVTCCLM(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(001000,0100),RLSE),
//       DCB=(MX.A,LRECL=0050,RECFM=FB)
//SYSIN    DD *
 SORT FIELDS=(1,3,PD,A,4,4,PD,A)
 END
//*
//STEP2    EXEC PGM=GFCT3408
//*
//* ***    OBTEM INFORMACOES DA MESU E CLIE
//* ***    DATA DE ABERTURA, DIRETORIA, GERENCIA E UF.
//*
//CLIEDESC DD DSN=*.STEP0.SORTOUT,
//       DISP=SHR
//RELCREDI DD DSN=*.STEP1A.SORT.SORTOUT,
//       DISP=SHR
//RELCREDS DD DSN=MX.GFCT.RELCREM.GFCT5195(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SYSOUT   DD SYSOUT=*
//SYSTSPRT DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP3    EXEC SORTD
//*
//* ***    ORGANIZA ARQUIVO RELCRED  - GFCTWANE
//* ***    ORDEM: WANE-TARIFA, WANE-DIRETORIA , WANE-GERENCIA
//*
//SORTIN   DD DSN=*.STEP2.RELCREDS,
//       DISP=SHR
//SORTOUT  DD DSN=MX.GFCT.RELCREX.GFCT5195(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SYSIN    DD *
  SORT FIELDS=(8,3,PD,A,37,5,ZD,A,42,5,ZD,A)
  END
//*
//STEP4    EXEC PGM=GFCT3412
//*
//* ***    GERA ARQUIVO DE TOTALIZACAO TOTCREDI
//*
//GFCTWANE DD DSN=*.STEP3.SORT.SORTOUT,
//       DISP=SHR
//GFCTWANF DD DSN=MX.GFCT.TOTCREM.GFCT5195(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SYSOUT   DD SYSOUT=*
//SYSTSPRT DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP5    EXEC SORTD
//*
//* ***    SEPARA RELCRED POR TARIFAS
//* ***    1123 1124 1125 1127 1129, 1133, 1134
//* ***    CLASSIFICANDO POR: WANE-DIRETORIA, WANE-GERENCIA,
//* ***                       WANE-AGENCIA  , WANE-PAB,
//* ***                       WANE-CONTA
//*
//SORTIN   DD DSN=*.STEP3.SORT.SORTOUT,
//       DISP=SHR
//SORTOUT1 DD DSN=MX.GFCT.RELCRET.TARI1123(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SORTOUT2 DD DSN=MX.GFCT.RELCRET.TARI1124(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SORTOUT3 DD DSN=MX.GFCT.RELCRET.TARI1125(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SORTOUT4 DD DSN=MX.GFCT.RELCRET.TARI1127(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SORTOUT5 DD DSN=MX.GFCT.RELCRET.TARI1129(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SORTOUT6 DD DSN=MX.GFCT.RELCRET.TARI1133(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SORTOUT7 DD DSN=MX.GFCT.RELCRET.TARI1134(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0070,RECFM=FB)
//SYSIN    DD *
  SORT FIELDS=(37,5,ZD,A,42,5,ZD,A,1,3,PD,A,47,5,ZD,A,4,4,PD,A)
  OUTFIL INCLUDE=(8,3,PD,EQ,1123),FNAMES=SORTOUT1
  OUTFIL INCLUDE=(8,3,PD,EQ,1124),FNAMES=SORTOUT2
  OUTFIL INCLUDE=(8,3,PD,EQ,1125),FNAMES=SORTOUT3
  OUTFIL INCLUDE=(8,3,PD,EQ,1127),FNAMES=SORTOUT4
  OUTFIL INCLUDE=(8,3,PD,EQ,1129),FNAMES=SORTOUT5
  OUTFIL INCLUDE=(8,3,PD,EQ,1133),FNAMES=SORTOUT6
  OUTFIL INCLUDE=(8,3,PD,EQ,1134),FNAMES=SORTOUT7
  END
//*
//STEP6    EXEC SORTD
//*
//* ***    SEPARA TOTCRED POR TARIFAS
//* ***    1123 1124 1125 1127 1129, 1133, 1134
//* ***    CLASSIFICANDO POR: WANF-DIRETORIA, WANF-GERENCIA
//*
//SORTIN   DD DSN=*.STEP4.GFCTWANF,
//       DISP=SHR
//SORTOUT1 DD DSN=MX.GFCT.TOTCRET.TARI1123(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SORTOUT2 DD DSN=MX.GFCT.TOTCRET.TARI1124(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SORTOUT3 DD DSN=MX.GFCT.TOTCRET.TARI1125(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SORTOUT4 DD DSN=MX.GFCT.TOTCRET.TARI1127(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SORTOUT5 DD DSN=MX.GFCT.TOTCRET.TARI1129(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SORTOUT6 DD DSN=MX.GFCT.TOTCRET.TARI1133(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SORTOUT7 DD DSN=MX.GFCT.TOTCRET.TARI1134(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0040,RECFM=FB)
//SYSIN    DD *
  SORT FIELDS=(7,5,ZD,A,1,1,ZD,A,21,5,ZD,A)
  OUTFIL INCLUDE=(2,5,ZD,EQ,1123),FNAMES=SORTOUT1
  OUTFIL INCLUDE=(2,5,ZD,EQ,1124),FNAMES=SORTOUT2
  OUTFIL INCLUDE=(2,5,ZD,EQ,1125),FNAMES=SORTOUT3
  OUTFIL INCLUDE=(2,5,ZD,EQ,1127),FNAMES=SORTOUT4
  OUTFIL INCLUDE=(2,5,ZD,EQ,1129),FNAMES=SORTOUT5
  OUTFIL INCLUDE=(2,5,ZD,EQ,1133),FNAMES=SORTOUT6
  OUTFIL INCLUDE=(2,5,ZD,EQ,1134),FNAMES=SORTOUT7
  END
