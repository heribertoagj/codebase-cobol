//*
//STEP8H   EXEC PGM=GFCT3720,
//       PARM=0001133
//*
//* ***    GERA ARQUIVO PARA RELATORIO DA TARIFA 1133
//*
//RELCREDI DD DSN=*.STEP5.SORT.SORTOUT6,
//       DISP=SHR
//TOTCREDI DD DSN=*.STEP6.SORT.SORTOUT6,
//       DISP=SHR
//RELATO   DD DSN=MX.GFCT.RELP1133(+1),
