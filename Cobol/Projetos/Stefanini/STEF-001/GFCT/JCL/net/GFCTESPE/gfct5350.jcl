//SYSOUT   DD SYSOUT=*
//SYSTSPRT DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP8K   EXEC PGM=PLAN2440,
//       PARM=001
//*
//* ***    EMITE RELATORIO TARIFA 1134
//*
//ENT00001 DD DSN=*.STEP8J.RELATO,
//       DISP=SHR
//SAI00001 DD SYSOUT=%%FORM#LAOK,
//       DCB=(LRECL=133,RECFM=FBA)
//SYSOUT   DD SYSOUT=*
//PRINTER  DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
