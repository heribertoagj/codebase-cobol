//* ***    GERA ARQUIVO PARA RELATORIO DA TARIFA 1125
//*
//RELCREDI DD DSN=*.STEP5.SORT.SORTOUT3,
//       DISP=SHR
//TOTCREDI DD DSN=*.STEP6.SORT.SORTOUT3,
//       DISP=SHR
//RELATO   DD DSN=MX.GFCT.RELP1125(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
