//SYSOUT   DD SYSOUT=*
//PRINTER  DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP8F   EXEC PGM=GFCT3720,
//       PARM=0001129
//*
//* ***    GERA ARQUIVO PARA RELATORIO DA TARIFA 1129
//*
//RELCREDI DD DSN=*.STEP5.SORT.SORTOUT5,
//       DISP=SHR
//TOTCREDI DD DSN=*.STEP6.SORT.SORTOUT5,
//       DISP=SHR
//RELATO   DD DSN=MX.GFCT.RELP1129(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=DISCO,
//       SPACE=(TRK,(010000,2000),RLSE),
//       DCB=(MX.A,LRECL=0133,RECFM=FB)
//SYSOUT   DD SYSOUT=*
//SYSTSPRT DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP8G   EXEC PGM=PLAN2440,
//       PARM=001
//*
//* ***    EMITE RELATORIO TARIFA 1129
//*
//ENT00001 DD DSN=*.STEP8F.RELATO,
//       DISP=SHR
//SAI00001 DD SYSOUT=%%FORM#IOMF,
