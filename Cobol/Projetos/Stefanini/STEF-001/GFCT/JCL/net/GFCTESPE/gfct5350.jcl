//* ***    EMITE RELATORIO TARIFA 1125
//*
//ENT00001 DD DSN=*.STEP8B.RELATO,
//       DISP=SHR
//SAI00001 DD SYSOUT=%%FORM#IOMD,
//       DCB=(LRECL=133,RECFM=FBA)
//SYSOUT   DD SYSOUT=*
//PRINTER  DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP8D   EXEC PGM=GFCT3720,
//       PARM=0001127
//*
