//SORTWK19 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK20 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//*
//STEP2    EXEC PGM=POOL0262
//*
//* ***    GERA CLIENTE REDUZIDO, DESCOMPRIMIDO.
//* ***    CLASSIFICANDO POR: AGENCIA E CONTA
//*
//SORTIN   DD DSN=MJ.CLIE.PRP.CADNOVGR.ALFA(0),
//       DISP=SHR
//SORTOUT  DD DSN=MX.GFCT.CLIEADES.GFCTN060(+1),
//       DISP=(,CATLG,CATLG),
//       UNIT=(DISCO,30),
//       SPACE=(TRK,(099900,19980),RLSE),
//       DCB=(MX.A,LRECL=0055,RECFM=FB)
//SYSIN    DD *
  SORT FIELDS=(1,3,A,7,4,A),FORMAT=BI
  OUTREC FIELDS=(1,10,10C'0',1Z,126,2,133,5,12,9,21,4,25,2,12X)
  END
