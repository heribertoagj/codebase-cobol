//GFCTN060 JOB 'GFCT,4220,PR14','B142376',MSGCLASS=Z,SCHENV=BATCH
//JOBLIB   DD DSN=MX.BIBGERAL,DISP=SHR
//         DD DSN=SYS1.CEE.SCEERUN,DISP=SHR
//STEP1    EXEC SORTD
//*
//* ***    CLASSIFICA O ARQUIVO DE CONTRATOS DE ADESAO A
//* ***    PACOTES NO PERIODO ATUAL, POR: AGENCIA E CONTA
//*
//SORTIN   DD DSN=MX.GFCT.PRV.ADMESCOR(0),
//       DISP=SHR
//SORTOUT  DD DSN=MX.GFCT.ADMESCOR.GFCTN060.CLASS(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,18),
//       SPACE=(TRK,(089830,17966),RLSE),
//       DCB=(MX.A,LRECL=0030,RECFM=FB)
//SYSIN    DD *
  SORT FIELDS=(1,3,A,4,4,A),FORMAT=BI
  END
//SORTLIB  DD DSN=SYS1.SORTLIB,
//       DISP=SHR
//SORTWK01 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK02 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
