//       SPACE=(CYL,(3200))
//SORTWK12 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK13 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK14 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK15 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK16 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK17 DD UNIT=(DISCO,59),
