//       SPACE=(CYL,(3200))
//SORTWK20 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SYSOUT   DD SYSOUT=*
//SYSUDUMP DD SYSOUT=Y
//*
//STEP3    EXEC SORTD
//*
//* ***    SELECIONAR APENAS CLIENTES PESSOA JURIDICA
//*
//SORTIN   DD DSN=*.STEP2.SORTOUT,
//       DISP=SHR
//SORTOUT  DD DSN=MX.GFCT.CLIEADES.GFCTN060.CLASS(+1),
//       DISP=(,CATLG,DELETE),
//       UNIT=(DISCO,59),
//       SPACE=(TRK,(030000,5000),RLSE),
//       DCB=(MX.A,LRECL=0055,RECFM=FB)
//SYSIN    DD *
  INCLUDE COND=(49,4,PD,NE,0)
  SORT FIELDS=COPY
  END
//SORTLIB  DD DSN=SYS1.SORTLIB,
//       DISP=SHR
//SORTWK01 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK02 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK03 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK04 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK05 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK06 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK07 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK08 DD UNIT=(DISCO,59),
//       SPACE=(CYL,(3200))
//SORTWK09 DD UNIT=(DISCO,59),
